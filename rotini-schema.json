{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Rotini CLI Spec Schema",
  "description": "Combined schema for a Rotini CLI spec file (.rotini.json)",
  "type": "object",
  "required": [
    "$schema",
    "definition",
    "configuration"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "URL identifying the rotini schema version. The version segment must match the installed rotini binary version.",
      "pattern": "^https://raw\\.githubusercontent\\.com/matthewgetz/config/refs/tags/[0-9]+\\.[0-9]+\\.[0-9]+/rotini-schema\\.json$"
    },
    "definition": {
      "$ref": "#/definitions/Definition"
    },
    "configuration": {
      "$ref": "#/definitions/Configuration"
    }
  },
  "definitions": {
    "Definition": {
      "$ref": "#/definitions/Command"
    },
    "Components": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schemas": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/Schema"
          }
        }
      }
    },
    "Command": {
      "type": "object",
      "required": [
        "name"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$"
        },
        "short_description": {
          "type": "string",
          "description": "One-line description shown in parent help output"
        },
        "long_description": {
          "type": "string",
          "description": "Detailed description shown in per-command help output"
        },
        "examples": {
          "type": "string",
          "description": "Example usage text shown in per-command help output"
        },
        "usage": {
          "type": "string",
          "description": "Custom usage string shown instead of auto-generated usage line"
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$"
          }
        },
        "hidden": {
          "type": "boolean",
          "default": false
        },
        "deprecated": {
          "type": "boolean",
          "default": false
        },
        "deprecated_message": {
          "type": "string",
          "description": "Message shown when this command is used (deprecated only)"
        },
        "inputs": {
          "$ref": "#/definitions/Inputs",
          "description": "Typed inputs for this command: flags, arguments, configuration file values, and environment variables"
        },
        "constraints": {
          "$ref": "#/definitions/Constraints"
        },
        "outputs": {
          "type": "object",
          "description": "Named output definitions for the command's Run handler",
          "additionalProperties": {
            "$ref": "#/definitions/Response"
          }
        },
        "output": {
          "$ref": "#/definitions/OutputSpec",
          "description": "Default output format and stream for this command's outputs"
        },
        "builtin": {
          "type": "string",
          "enum": [
            "help",
            "completions",
            "docs",
            "version"
          ],
          "description": "Opt-in built-in handler behavior. When set, generates a pre-written handler implementation instead of an empty stub."
        },
        "commands": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Command"
          }
        },
        "components": {
          "$ref": "#/definitions/Components",
          "description": "Reusable schema definitions. Only meaningful at the root level."
        },
        "configuration_files": {
          "type": "array",
          "description": "Config files to load at startup. Only meaningful at the root level.",
          "items": {
            "$ref": "#/definitions/ConfigSpec"
          }
        },
        "external_binaries": {
          "type": "array",
          "description": "External CLI binaries the framework can dispatch to. Only meaningful at the root level.",
          "items": {
            "$ref": "#/definitions/ExternalBinary"
          }
        },
        "command_groups": {
          "type": "array",
          "description": "Named groups for organising commands in help output. Only meaningful at the root level.",
          "items": {
            "$ref": "#/definitions/CommandGroup"
          }
        },
        "validation": {
          "$ref": "#/definitions/ValidationSpec",
          "description": "Validation behaviour configuration. Only meaningful at the root level."
        },
        "plugins": {
          "$ref": "#/definitions/PluginsSpec",
          "description": "Plugin discovery configuration. Only meaningful at the root level."
        },
        "timeout": {
          "type": "integer",
          "minimum": 0,
          "description": "Command execution timeout in milliseconds. Zero means no timeout."
        },
        "passthrough": {
          "type": "boolean",
          "default": false,
          "description": "When true, tokens after '--' are collected as passthrough arguments"
        },
        "stdin": {
          "$ref": "#/definitions/StdinSpec",
          "description": "Declares expected stdin format and schema for this command"
        },
        "group": {
          "type": "string",
          "description": "Group label matching a command_groups entry. Controls help output grouping."
        },
        "persistent_pre_run": {
          "type": "boolean",
          "default": false,
          "description": "When true, PreRun is also called for all descendant commands"
        }
      }
    },
    "Inputs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "flags": {
          "type": "array",
          "description": "Flag inputs for this command",
          "items": {
            "$ref": "#/definitions/FlagInput"
          }
        },
        "arguments": {
          "type": "array",
          "description": "Positional argument inputs for this command",
          "items": {
            "$ref": "#/definitions/ArgumentInput"
          }
        },
        "configuration_files": {
          "type": "array",
          "description": "Config file value inputs for this command",
          "items": {
            "$ref": "#/definitions/ConfigInput"
          }
        },
        "env": {
          "type": "array",
          "description": "Environment variable inputs for this command",
          "items": {
            "$ref": "#/definitions/EnvInput"
          }
        }
      }
    },
    "FlagInput": {
      "type": "object",
      "required": [
        "name"
      ],
      "additionalProperties": false,
      "if": {
        "not": {
          "properties": {
            "action": {
              "const": true
            }
          },
          "required": [
            "action"
          ]
        }
      },
      "then": {
        "properties": {
          "outputs": false
        }
      },
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
          "description": "Logical name for the flag"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description shown in help output"
        },
        "required": {
          "type": "boolean",
          "default": false
        },
        "deprecated": {
          "type": "boolean",
          "default": false
        },
        "deprecated_message": {
          "type": "string",
          "description": "Message shown when this flag is used (deprecated only)"
        },
        "sensitive": {
          "type": "boolean",
          "default": false,
          "description": "When true, value is treated as sensitive (not logged)"
        },
        "schema": {
          "$ref": "#/definitions/Schema"
        },
        "default": {
          "type": "string",
          "description": "Default value when the flag is not provided"
        },
        "completions": {
          "type": "boolean",
          "default": false,
          "description": "Enable dynamic completion callback for this flag"
        },
        "identifiers": {
          "type": "array",
          "description": "CLI flag identifiers (e.g., '--force', '-f')",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^-{1,2}[a-zA-Z][a-zA-Z0-9_-]*$"
          }
        },
        "action": {
          "type": "boolean",
          "default": false,
          "description": "When true, the flag is an action flag: it triggers an operation and may define typed outputs. When false (default), the flag is a modifier flag."
        },
        "hidden": {
          "type": "boolean",
          "default": false,
          "description": "When true, the flag is hidden from help output"
        },
        "persistent": {
          "type": "boolean",
          "default": false,
          "description": "When true, the flag propagates to all subcommands"
        },
        "count": {
          "type": "boolean",
          "default": false,
          "description": "When true, counts flag repetitions as an integer value (e.g., -vvv = 3). Requires schema.type == 'int'."
        },
        "placeholder": {
          "type": "string",
          "description": "Custom placeholder shown in help usage lines"
        },
        "negation": {
          "type": "boolean",
          "default": false,
          "description": "When true, generates a paired --no-<name> boolean flag"
        },
        "env": {
          "type": "string",
          "description": "Fallback environment variable name (checked when flag is not provided)",
          "pattern": "^[A-Z_][A-Z0-9_]*$"
        },
        "outputs": {
          "type": "object",
          "description": "Named output definitions for action flags. Only valid when action == true.",
          "additionalProperties": {
            "$ref": "#/definitions/Response"
          }
        }
      }
    },
    "ArgumentInput": {
      "type": "object",
      "required": [
        "name"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
          "description": "Logical name for the argument"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description shown in help output"
        },
        "required": {
          "type": "boolean",
          "default": false
        },
        "deprecated": {
          "type": "boolean",
          "default": false
        },
        "deprecated_message": {
          "type": "string"
        },
        "sensitive": {
          "type": "boolean",
          "default": false
        },
        "schema": {
          "$ref": "#/definitions/Schema"
        },
        "default": {
          "type": "string"
        },
        "completions": {
          "type": "boolean",
          "default": false
        },
        "variadic": {
          "type": "boolean",
          "default": false,
          "description": "When true, collects all remaining positional values"
        },
        "stdin_dash": {
          "type": "boolean",
          "default": false,
          "description": "When true, '-' as the argument value reads from stdin"
        },
        "format": {
          "type": "string",
          "description": "Input format for stdin_dash reads (e.g., 'json', 'text')"
        },
        "env": {
          "type": "string",
          "description": "Fallback environment variable name (checked when argument is not provided)",
          "pattern": "^[A-Z_][A-Z0-9_]*$"
        }
      }
    },
    "ConfigInput": {
      "type": "object",
      "required": [
        "name",
        "file",
        "key"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
          "description": "Logical name for this config value"
        },
        "description": {
          "type": "string"
        },
        "required": {
          "type": "boolean",
          "default": false
        },
        "schema": {
          "$ref": "#/definitions/Schema"
        },
        "default": {
          "type": "string"
        },
        "file": {
          "type": "string",
          "description": "Config file path"
        },
        "key": {
          "type": "string",
          "description": "Key path within the config file (e.g., 'server.port')"
        }
      }
    },
    "EnvInput": {
      "type": "object",
      "required": [
        "name",
        "env"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$",
          "description": "Logical name for this env var input"
        },
        "description": {
          "type": "string"
        },
        "required": {
          "type": "boolean",
          "default": false
        },
        "schema": {
          "$ref": "#/definitions/Schema"
        },
        "default": {
          "type": "string"
        },
        "env": {
          "type": "string",
          "description": "Environment variable name",
          "pattern": "^[A-Z_][A-Z0-9_]*$"
        }
      }
    },
    "StdinSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "format": {
          "type": "string",
          "description": "Expected stdin format: 'json', 'text', 'csv'"
        },
        "required": {
          "type": "boolean",
          "default": false,
          "description": "When true, error if stdin is empty"
        },
        "schema": {
          "$ref": "#/definitions/Schema"
        }
      }
    },
    "Constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "oneOf": {
          "type": "array",
          "description": "Exactly one group of named inputs must be provided (mutually exclusive)",
          "items": {
            "$ref": "#/definitions/ConstraintGroup"
          }
        },
        "allOf": {
          "type": "array",
          "description": "All named inputs in each group must be provided together",
          "items": {
            "$ref": "#/definitions/ConstraintGroup"
          }
        },
        "anyOf": {
          "type": "array",
          "description": "At least one group of named inputs must satisfy the constraint",
          "items": {
            "$ref": "#/definitions/ConstraintGroup"
          }
        },
        "not": {
          "type": "array",
          "description": "None of the named inputs in each group may be provided together",
          "items": {
            "$ref": "#/definitions/ConstraintGroup"
          }
        },
        "args": {
          "$ref": "#/definitions/ArgsConstraint",
          "description": "Positional argument count constraints"
        }
      }
    },
    "Display": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "header": {
          "type": "string",
          "description": "Column header label"
        },
        "width": {
          "type": "integer",
          "minimum": 1,
          "description": "Minimum column width in characters"
        },
        "omit": {
          "type": "boolean",
          "default": false,
          "description": "When true, exclude this field from table output"
        }
      }
    },
    "OutputSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "format": {
          "type": "string",
          "enum": [
            "json",
            "table",
            "text"
          ],
          "default": "text",
          "description": "Default output format for all outputs"
        },
        "stream": {
          "type": "string",
          "enum": [
            "stdout",
            "stderr"
          ],
          "default": "stdout",
          "description": "Default output stream for all outputs"
        }
      }
    },
    "Condition": {
      "type": "object",
      "required": [
        "param"
      ],
      "additionalProperties": false,
      "properties": {
        "param": {
          "type": "string",
          "description": "Name of the input to check"
        },
        "equals": {
          "type": "string",
          "description": "Condition is true when the input's value equals this string"
        },
        "present": {
          "type": "boolean",
          "description": "Condition is true when the input was explicitly provided"
        }
      }
    },
    "ConstraintGroup": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "when": {
          "type": "array",
          "description": "All conditions must be true for this group to activate (allOf semantics). When absent, the group is unconditional.",
          "items": {
            "$ref": "#/definitions/Condition"
          }
        },
        "required": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "ArgsConstraint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "min": {
          "type": "integer",
          "minimum": 0,
          "description": "Minimum number of positional arguments required"
        },
        "max": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum number of positional arguments allowed"
        },
        "exact": {
          "type": "integer",
          "minimum": 0,
          "description": "Exact number of positional arguments required"
        }
      }
    },
    "Response": {
      "type": "object",
      "additionalProperties": false,
      "if": {
        "not": {
          "required": [
            "$ref"
          ]
        }
      },
      "then": {
        "required": [
          "exit_code"
        ]
      },
      "properties": {
        "$ref": {
          "type": "string",
          "description": "Reference to a component schema definition. Resolved at codegen time."
        },
        "exit_code": {
          "type": "integer",
          "description": "Exit code for this output (0 for success, non-zero for error/warning)"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of this output"
        },
        "schema": {
          "$ref": "#/definitions/Schema"
        },
        "format": {
          "type": "string",
          "enum": [
            "json",
            "table",
            "text"
          ],
          "description": "Overrides command-level output format for this response only"
        },
        "stream": {
          "type": "string",
          "enum": [
            "stdout",
            "stderr"
          ],
          "description": "Overrides command-level output stream for this response only"
        }
      }
    },
    "Schema": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "$ref": {
          "type": "string",
          "description": "Reference to a component schema definition (e.g. '#/definition/components/schemas/MySchema'). Resolved at codegen time — the referenced schema is inlined before code generation."
        },
        "type": {
          "type": "string",
          "description": "The type used to parse and store the value. Accepts both Go type names (bool, int, float64, []string, duration, map) and JSON Schema standard names (boolean, integer, number, array, object) — both are equivalent. Custom Go types are also accepted (e.g. 'url.URL') when the required package is listed in configuration.package.imports."
        },
        "nullable": {
          "type": "boolean",
          "default": false
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "format": {
          "type": "string"
        },
        "enum": {
          "type": "array",
          "description": "Allowed values; parsed values are validated against this list",
          "items": {
            "type": "string"
          }
        },
        "const": {},
        "pattern": {
          "type": "string",
          "description": "Regular expression the value must match (string type only)"
        },
        "minimum": {
          "type": "number",
          "description": "Minimum allowed value (numeric types only)"
        },
        "maximum": {
          "type": "number",
          "description": "Maximum allowed value (numeric types only)"
        },
        "exclusiveMinimum": {
          "type": "number"
        },
        "exclusiveMaximum": {
          "type": "number"
        },
        "multipleOf": {
          "type": "number"
        },
        "minLength": {
          "type": "integer",
          "minimum": 0,
          "description": "Minimum string length (string type only)"
        },
        "maxLength": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum string length (string type only)"
        },
        "minItems": {
          "type": "integer",
          "minimum": 0
        },
        "maxItems": {
          "type": "integer",
          "minimum": 0
        },
        "uniqueItems": {
          "type": "boolean",
          "default": false
        },
        "required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "properties": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/Schema"
          }
        },
        "additionalProperties": {},
        "items": {
          "$ref": "#/definitions/Schema"
        },
        "allOf": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Schema"
          }
        },
        "anyOf": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Schema"
          }
        },
        "oneOf": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Schema"
          }
        },
        "not": {
          "$ref": "#/definitions/Schema"
        },
        "display": {
          "$ref": "#/definitions/Display",
          "description": "Table rendering hints for this property"
        }
      }
    },
    "ConfigSpec": {
      "type": "object",
      "required": [
        "name",
        "path"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Logical name for the config file (e.g., 'app-config')"
        },
        "path": {
          "type": "string",
          "description": "File path (supports ~ for home dir)"
        },
        "format": {
          "type": "string",
          "enum": [
            "json",
            "yaml",
            "toml"
          ],
          "default": "json",
          "description": "Config file format"
        },
        "watch": {
          "type": "boolean",
          "default": true,
          "description": "When false, disables file watching for this config. Default true."
        }
      }
    },
    "ExternalBinary": {
      "type": "object",
      "required": [
        "name"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Binary name as it appears in $PATH"
        },
        "description": {
          "type": "string",
          "description": "Short description shown in help output"
        },
        "required": {
          "type": "boolean",
          "default": false,
          "description": "When true, startup fails if the binary is not found in $PATH"
        },
        "min_version": {
          "type": "string",
          "description": "Minimum required semver version (e.g. '1.2.0')"
        },
        "version_flag": {
          "type": "string",
          "description": "Flag used to retrieve the binary version (e.g. '--version')"
        }
      }
    },
    "CommandGroup": {
      "type": "object",
      "required": [
        "name"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Group label matching the 'group' field on commands"
        },
        "description": {
          "type": "string",
          "description": "Optional description shown next to the group header in help output"
        }
      }
    },
    "ValidationSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "behavior": {
          "type": "string",
          "enum": ["fail_fast", "fail_collect"],
          "default": "fail_fast",
          "description": "fail_fast stops at the first validation error (default); fail_collect gathers all errors before returning"
        }
      }
    },
    "PluginsSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path_discovery": {
          "type": "boolean",
          "default": false,
          "description": "When true, scan $PATH for <program>-<command> binaries at startup"
        }
      }
    },
    "Configuration": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "package": {
          "$ref": "#/definitions/ConfigPackage"
        }
      }
    },
    "ConfigPackage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "description": "Base path for generated code. Framework is written to {path}/rotini/rotini.gen.go and handlers to {path}/cmd/rotini.gen.go.",
          "default": "internal/cli"
        },
        "imports": {
          "type": "array",
          "description": "List of Go import paths to include in generated code as a convenience if types from external packages are desired in input or output types. Each entry is a package path (e.g., 'net/url') or an aliased import (e.g., 'myalias net/url').",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
